# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Obtenha em: https://console.cloudinary.com → Settings → API Keys

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nome do Upload Preset criado no Cloudinary (deve ser "Unsigned")
# Crie em: Settings → Upload → Upload presets → Add upload preset
CLOUDINARY_UPLOAD_PRESET=midia-converter
